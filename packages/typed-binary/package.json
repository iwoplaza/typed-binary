{
  "name": "typed-binary",
  "version": "4.3.2",
  "description": "Describe binary structures with full TypeScript support. Encode and decode into pure JavaScript objects.",
  "keywords": [
    "arraybuffer",
    "backend",
    "bin",
    "binary",
    "buffer",
    "data",
    "decoding",
    "deserialization",
    "deserialize",
    "encoding",
    "front-end",
    "json",
    "schema",
    "serial",
    "serialization",
    "serialize",
    "structure",
    "type",
    "typed",
    "types",
    "typescript"
  ],
  "homepage": "https://iwoplaza.github.io/typed-binary/",
  "bugs": {
    "url": "https://github.com/iwoplaza/typed-binary/issues"
  },
  "license": "MIT",
  "author": "Iwo Plaza <iwoplaza@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/iwoplaza/typed-binary.git"
  },
  "files": [
    "README.md",
    "LICENSE",
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      "./package.json": "./package.json",
      ".": {
        "types": "./dist/index.d.ts",
        "module": "./dist/index.js",
        "import": "./dist/index.js",
        "default": "./dist/index.cjs"
      },
      "./*": {
        "types": "./*.d.ts",
        "module": "./dist/*.js",
        "import": "./dist/*.js",
        "default": "./dist/*.cjs"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "prepublishOnly": "pnpm -w run check && pnpm -w run build",
    "dryPublish": "pnpm publish --dry-run",
    "publish-package": "node ../../scripts/publish-to-npm.mjs",
    "check": "tsup"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "tsup": "8.1.0",
    "typescript": "catalog:"
  }
}
